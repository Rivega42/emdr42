# ===========================================
# EMDR42 Environment Variables
# ===========================================
#
# ВАЖНО: docker-compose использует ${VAR:?} для обязательных переменных.
# Без установки они не дадут сервису стартануть — это намеренно.
#
# В production:
#   1. Заполните все переменные с "CHANGE_ME" через openssl rand -base64 32
#   2. Храните секреты в vault / K8s secrets, а не в .env
#   3. Убедитесь, что .env в .gitignore

# ===========================================
# Database (REQUIRED)
# ===========================================
POSTGRES_PASSWORD=CHANGE_ME_generate_via_openssl_rand_base64_24
DATABASE_URL=postgresql://emdr42:${POSTGRES_PASSWORD}@localhost:5432/emdr42

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# Secrets (REQUIRED)
# ===========================================
# Генерация: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_min_32_chars_random_base64
PHI_ENCRYPTION_KEY=CHANGE_ME_min_32_chars_random_base64

# ===========================================
# Environment
# ===========================================
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ===========================================
# LiveKit (WebRTC) - Self-hosted (REQUIRED)
# ===========================================
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey_CHANGE_ME_in_production
LIVEKIT_API_SECRET=CHANGE_ME_openssl_rand_base64_32

# ===========================================
# MinIO / S3 Storage (REQUIRED for recordings)
# ===========================================
MINIO_ROOT_USER=emdr42
MINIO_ROOT_PASSWORD=CHANGE_ME_min_20_chars

# ===========================================
# Grafana
# ===========================================
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_min_16_chars

# ===========================================
# AI Providers - Local (Primary)
# ===========================================

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b
# Альтернативы: mistral:7b, mixtral:8x7b, qwen2.5:14b

# Faster-Whisper (Local STT)
WHISPER_BASE_URL=http://localhost:8001
# Models: tiny, base, small, medium, large-v3

# Piper (Local TTS)
PIPER_BASE_URL=http://localhost:5000

# ===========================================
# AI Providers - Cloud (Fallback)
# ===========================================

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=

# OpenAI (optional fallback)  
OPENAI_API_KEY=

# Deepgram STT (optional fallback)
DEEPGRAM_API_KEY=

# ElevenLabs TTS (optional fallback)
ELEVENLABS_API_KEY=

# ===========================================
# Email (optional)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ===========================================
# Server (for deployment)
# ===========================================
SERVER_HOST=
SERVER_USER=root
