# ===========================================
# EMDR42 Environment Variables
# ===========================================

# Database
DATABASE_URL=postgresql://emdr42:emdr42_secret@localhost:5432/emdr42

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secret (generate: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# PHI Encryption Key (generate: openssl rand -base64 32)
PHI_ENCRYPTION_KEY=your-phi-encryption-key-change-this

# Node Environment
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:3000

# ===========================================
# LiveKit (WebRTC) - Self-hosted
# ===========================================
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# Для production: openssl rand -base64 32

# ===========================================
# AI Providers - Local (Primary)
# ===========================================

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b
# Альтернативы: mistral:7b, mixtral:8x7b, qwen2.5:14b

# Faster-Whisper (Local STT)
WHISPER_BASE_URL=http://localhost:8001
# Models: tiny, base, small, medium, large-v3

# Piper (Local TTS)
PIPER_BASE_URL=http://localhost:5000

# ===========================================
# AI Providers - Cloud (Fallback)
# ===========================================

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=

# OpenAI (optional fallback)  
OPENAI_API_KEY=

# Deepgram STT (optional fallback)
DEEPGRAM_API_KEY=

# ElevenLabs TTS (optional fallback)
ELEVENLABS_API_KEY=

# ===========================================
# Email (optional)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ===========================================
# Server (for deployment)
# ===========================================
SERVER_HOST=
SERVER_USER=root
