# ===========================================================
# EMDR42 — production .env для docker-compose.production.yml
# ===========================================================
# cp .env.production.example .env  и заполнить все CHANGE_ME.
# Генерация секретов: openssl rand -base64 32
# .env в .gitignore — НЕ коммитить.

# Тег образов ghcr.io/rivega42/emdr42-{api,orchestrator,gateway}.
# latest = последний main; для фиксации релиза укажите sha-тег (sha-XXXXXXX).
IMAGE_TAG=latest

# --- Публичные URL (вшиваются в build фронтенда!) ---
# После изменения нужен rebuild: docker compose ... build frontend
NEXT_PUBLIC_APP_URL=https://emdr42.ru
NEXT_PUBLIC_API_URL=https://emdr42.ru/api
NEXT_PUBLIC_WS_URL=https://emdr42.ru
NEXT_PUBLIC_LIVEKIT_URL=wss://emdr42.ru/livekit

# --- База данных ---
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_base64_24

# --- Секреты приложения ---
JWT_SECRET=CHANGE_ME_openssl_rand_base64_48
JWT_EXPIRES_IN=15m
PHI_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_base64_32

# --- LiveKit (WebRTC) ---
LIVEKIT_API_KEY=CHANGE_ME_short_key_id
LIVEKIT_API_SECRET=CHANGE_ME_openssl_rand_base64_32

# --- Cloud AI ---
# Для РАБОЧЕГО ИИ-диалога задайте хотя бы ANTHROPIC_API_KEY (primary) или
# OPENAI_API_KEY. Без ключа диалог недоступен — фронт показывает баннер
# «ИИ-ассистент недоступен» (BLS и эмоции работают). Локальных GPU-сервисов
# (ollama) на этом сервере нет. Распознавание эмоций ключей НЕ требует.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# --- Эмоции (face-api) ---
# Веса моделей self-hosted в public/models (см. scripts/fetch-face-models.sh).
# Переопределять не нужно; задайте только если веса размещены на другом origin.
# NEXT_PUBLIC_FACE_MODELS_URL=/models

# --- Email (опционально) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=noreply@emdr42.ru

# --- Stripe (опционально) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Sentry (опционально) ---
SENTRY_DSN=

# --- Web Push (опционально; npx web-push generate-vapid-keys) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@emdr42.ru
