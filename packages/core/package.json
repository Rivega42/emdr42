{
  "name": "@emdr42/core",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./patterns/movements": {
      "types": "./dist/patterns/movements.d.ts",
      "default": "./dist/patterns/movements.js"
    },
    "./services/emotion-recognition": {
      "types": "./dist/services/emotion-recognition.d.ts",
      "default": "./dist/services/emotion-recognition.js"
    },
    "./services/audio-asmr": {
      "types": "./dist/services/audio-asmr.d.ts",
      "default": "./dist/services/audio-asmr.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
